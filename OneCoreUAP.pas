var
  Lookup: TDictionary<string, string>;

procedure AddAPIs;
var
  i: Integer;
begin
  for i := Low(APISET_APIS) to High(APISET_APIS) do
    Lookup.Add(APISET_APIS[i][0], APISET_APIS[i][1]);
end;

function GetOneCoreUAPModuleByAPI(const API: string): string;
begin
  if not Lookup.TryGetValue(API, Result) then
    Result := '';
end;

initialization
  Lookup := TDictionary<string, string>.Create;
  AddAPIs;

finalization
  Lookup.Free;

end.
